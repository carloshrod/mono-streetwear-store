# Supabase — copy this file to .env.local and fill in your project values.
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — used for Checkout sessions and the order-fulfillment webhook.
# Test mode keys: dashboard.stripe.com/test/apikeys
# Webhook secret: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# (the CLI prints a whsec_... secret) or create an endpoint in the dashboard.
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Base URL used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend) — used for order confirmation + admin new-order notifications.
# Sender domain must be verified at resend.com/domains before sending to
# anyone other than your own Resend account email.
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=MONO <orders@yourdomain.com>
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com
